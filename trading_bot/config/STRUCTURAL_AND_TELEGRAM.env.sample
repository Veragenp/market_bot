# ============================================================================
# Пример .env для полного контура structural -> entry -> demo execution.
# Куда класть:
#   1) trading_bot/.env    (приоритет ниже)
#   2) <repo>/.env         (может переопределять значения)
#
# ВАЖНО:
# - Секреты (API ключи, токены) НЕ коммитить в git.
# - Этот файл — шаблон с комментариями "что за что отвечает".
# ============================================================================

# ----------------------------- Telegram --------------------------------------
# Токен бота. Можно использовать TELEGRAM_TOKEN как алиас.
TELEGRAM_BOT_TOKEN=
# ID чата/канала для уведомлений. Можно использовать CHAT_ID как алиас.
TELEGRAM_CHAT_ID=

# ---------------------------- Google Sheets ----------------------------------
# Путь к JSON сервис-аккаунта Google (доступ к таблицам).
GOOGLE_CREDENTIALS_PATH=credentials.json
# URL книги для выгрузок (если указан, используется в приоритете).
MARKET_AUDIT_SHEET_URL=
# ID книги для выгрузок (используется, если URL пустой).
MARKET_AUDIT_SHEET_ID=
# Название книги (fallback, если URL/ID не заданы).
MARKET_AUDIT_SHEET_TITLE=Market Data Audit

# ----------------------------- Bybit API -------------------------------------
# Режим Demo (1) или Prod (0).
BYBIT_USE_DEMO=1
# Demo API key/secret (обязательно при BYBIT_USE_DEMO=1).
BYBIT_API_KEY_TEST=
BYBIT_API_SECRET_TEST=
# Prod API key/secret (обязательно при BYBIT_USE_DEMO=0).
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Глобальный "рубильник" отправки ордеров:
# 0 - ордера не отправляются (безопасный режим),
# 1 - ордера разрешены.
BYBIT_EXECUTION_ENABLED=0
#
# Авто-ордера после группового LONG/SHORT (entry_gate), в том же тике что и подтверждения:
#   BYBIT_EXECUTION_ENABLED=1
#   ENTRY_AUTO_OPEN_AFTER_GATE=1
#   ключи (demo: BYBIT_API_KEY_TEST / BYBIT_API_SECRET_TEST при BYBIT_USE_DEMO=1)
# Вход после гейта только лимитом GTC со встроенным stopLoss (рынок — только reduce-only для выходов).
# Базовый URL API Bybit (обычно менять не нужно).
BYBIT_BASE_URL=https://api.bybit.com
# Публичный WebSocket (price_feed, ликвидации): при 404/ELB — bytick, только с BYBIT_USE_DEMO=0.
# В демо (BYBIT_USE_DEMO=1) bytick игнорируется — всегда stream-demo.bybit.com.
# Если WS не коннектится, а REST отдаёт цены — отключите попытки WS (тише лог, без ретраев pybit):
#PRICE_FEED_WEBSOCKET_ENABLED=0
#BYBIT_WS_DOMAIN=bytick
#BYBIT_WS_TRACE_LOGGING=0
#BYBIT_WS_PING_INTERVAL=20
#BYBIT_WS_PING_TIMEOUT=10
#BYBIT_WS_RETRIES=10

# -------------------------- Structural: скан/цикл ----------------------------
# Источник ref-цены для structural:
# - price_feed: Bybit WS/REST (рекомендуется для фьючерсов),
# - db_1m_close: последний close 1m из SQLite.
STRUCTURAL_REF_PRICE_SOURCE=price_feed

# Разрешенные типы уровней для structural (через запятую).
STRUCTURAL_ALLOWED_LEVEL_TYPES=vp_local,manual_global_hvn
# Минимум кандидатов снизу/сверху для символа.
STRUCTURAL_MIN_CANDIDATES_PER_SIDE=1
# Top-K кандидатов на сторону для перебора (совпадает с STRUCTURAL_SETTINGS.TOP_K_PER_SIDE).
STRUCTURAL_TOP_K=4
# Эталон W*=(U-L)/ATR: минимум монет с парой W в [W_MIN,W_MAX] для медианы.
STRUCTURAL_N_ETALON=3
STRUCTURAL_W_MIN=0.7
STRUCTURAL_W_MAX=2.5
# Доля от W*: effective_slack = max(W_SLACK_ABS_MIN, W* * PCT/100).
STRUCTURAL_W_SLACK_PCT=15
# Минимальный люфт в единицах W (не сужать полосу при малом W*).
STRUCTURAL_W_SLACK_ABS_MIN=0.3
# Полоса у линии L/U: PCT от ATR в цене (15 -> ±0.15*ATR), для realtime/спеки.
STRUCTURAL_EDGE_ATR_PCT=15
# Порог z_w = |W-W*|/slack в отчётах (pool_k в БД).
STRUCTURAL_Z_W_OK_THRESHOLD=1
# Минимум ok-символов после подгонки под W*.
STRUCTURAL_MIN_POOL_SYMBOLS=5
# Полу-ширина mid-полосы в % от ширины канала (U-L).
STRUCTURAL_MID_BAND_PCT=15
# При выборе пары сперва "сила уровней", потом геометрия.
STRUCTURAL_STRENGTH_FIRST_ENABLED=1

# Для cycle_levels_db (дозаполнение противоположной стороны), не для эталона:
STRUCTURAL_MAD_K=3
STRUCTURAL_REFINE_MAX_ROUNDS=5

# Режим freeze после scan:
# 1 - автоматически фиксировать уровни в cycle_levels,
# 0 - только scan без freeze.
STRUCTURAL_AUTO_FREEZE_ON_SCAN=1

# -------------------- Structural realtime: mid-touch/abort -------------------
# N уникальных символов, коснувшихся mid-полосы, чтобы перейти в entry_timer.
STRUCTURAL_N_TOUCH=5
# Окно (сек), в котором считаются касания для N_TOUCH.
STRUCTURAL_TOUCH_WINDOW_SEC=900
# Длительность entry_timer (сек) после набора N_TOUCH.
STRUCTURAL_ENTRY_TIMER_SEC=300
# N символов для коллективного abort (пробой канала).
STRUCTURAL_N_ABORT=5
# Дистанция abort от L/U в долях ATR.
STRUCTURAL_ABORT_DIST_ATR=0.25
# Дебаунс повторного mid-touch по одному символу (сек).
STRUCTURAL_TOUCH_DEBOUNCE_SEC=5
# Частота realtime polling (сек), если не override-тест.
STRUCTURAL_POLL_SEC=1.0
# Максимальная длительность realtime цикла (сек).
STRUCTURAL_MAX_RUNTIME_SEC=7200

# Историческое восстановление группового touch (после рестартов).
# Lookback (сек), в котором ищем уже случившийся grouped-touch.
STRUCTURAL_TOUCH_HISTORY_LOOKBACK_SEC=14400
# Минимум уникальных символов в lookback для recovery.
STRUCTURAL_TOUCH_HISTORY_MIN_SYMBOLS=5
# Дедуп grouped-touch события в одном cycle_id (сек).
STRUCTURAL_GROUP_TOUCH_DEDUP_SEC=300

# Достройка противоположной стороны после flip/single-sided.
STRUCTURAL_OPPOSITE_REBUILD_ENABLED=1
# Дедлайн на достройку противоположной стороны (сек). 4 часа = 14400.
STRUCTURAL_OPPOSITE_REBUILD_DEADLINE_SEC=14400
# Множитель диапазона ATR для rebuild opposite (fit_band = [W_MIN*mult, W_MAX*mult]).
STRUCTURAL_OPPOSITE_REBUILD_BAND_MULT=2.0

# ------------------------ Level cross / Entry gate ---------------------------
# Интервал тика monitor+entry (сек).
LEVEL_CROSS_POLL_SEC=10
# Таймаут окна группового сигнала (минуты).
LEVEL_CROSS_ALERT_TIMEOUT_MINUTES=60
# Мин. число разных символов в группе для сигнала.
LEVEL_CROSS_MIN_ALERTS_COUNT=4
# Макс. "добавочных" символов до отмены сценария.
LEVEL_CROSS_MAX_ADDITIONAL_ALERTS=10
# 1 — каждый тик entry: строка LevelCrossTick в лог (счётчики, ожидание таймаута).
LEVEL_CROSS_TICK_SUMMARY_LOG=1
# Порог подтверждения LONG в % ATR.
ENTRY_GATE_LONG_ATR_THRESHOLD_PCT=5
# Порог подтверждения SHORT в % ATR.
ENTRY_GATE_SHORT_ATR_THRESHOLD_PCT=5

# После прохождения гейта: авто-лимиты по строкам entry_gate_confirmations (нужен BYBIT_EXECUTION_ENABLED=1).
ENTRY_AUTO_OPEN_AFTER_GATE=0
# Лимитный вход со stopLoss в том же place_order (как tutorial_v3).
# Перед входом в противоположную сторону: закрыть пакет рынком (reduce-only), отменить pending лимиты.
ENTRY_CLOSE_OPPOSITE_ON_FLIP_SIGNAL=1
# После reconcile: пакет плоский → закрыть эпоху (closed + unfreeze), следующий проход сделает новый structural.
# Источник: position_records (если есть) или опрос Bybit get_positions по пулу.
ENTRY_PACKAGE_FLAT_TRANSITION=1
# Опрос биржи без исполнения ордеров: 1 + ключи (например только чтение позиций при «бумажном» гейте).
# Если 0: опрос Bybit включается автоматически при BYBIT_EXECUTION_ENABLED=1.
ENTRY_PACKAGE_FLAT_USE_BYBIT_POSITIONS=0

# Общий Telegram-флаг для level-cross/entry контура (групповой сигнал, гейт, flip и т.д.).
LEVEL_CROSS_TELEGRAM=1
# 0 — минимум: без Telegram на каждое пересечение уровня; 1 — каждое касание LONG/SHORT.
LEVEL_CROSS_TELEGRAM_CROSSINGS=0
# Старт каждого тика entry detector (часто — раз в SUPERVISOR_ENTRY_TICK_SEC). Токен/чат — как у остальных Telegram-джоб.
ENTRY_DETECTOR_TELEGRAM_START=0

# ----------------------- Position math / risk params -------------------------
# Фиксированный риск на символ (USDT).
POSITION_RISK_USDT=50
# Множитель ATR для Stop Loss.
POSITION_STOP_ATR_MULT=1
# Множители ATR для TP1/TP2/TP3 (используются в расчете плана).
POSITION_TP1_ATR_MULT=1
POSITION_TP2_ATR_MULT=2
POSITION_TP3_ATR_MULT=3
# Доли объема на TP1/TP2 (%), остаток уходит в TP3.
POSITION_TP1_SHARE_PCT=40
POSITION_TP2_SHARE_PCT=30
# Смещение входа в % ATR (если use_entry_offset=True в math).
POSITION_ENTRY_OFFSET_PCT=0

# ---------------------- Structural ops notifications --------------------------
# Лог structural-ивентов в stdout/логгер.
STRUCTURAL_OPS_LOG=1
# Telegram по structural-ивентам (phase/breakout/freeze).
STRUCTURAL_OPS_TELEGRAM=1
# Писать snapshot structural scan в Sheets (structural_levels_report).
STRUCTURAL_OPS_SHEETS_LEVELS=1
# Писать operational structural log в Sheets.
STRUCTURAL_OPS_SHEETS_LOG=0
# Писать каждый mid_touch в Telegram (шумно).
STRUCTURAL_OPS_TELEGRAM_EACH_MID_TOUCH=1
# Писать каждый mid_touch в Sheets log (шумно).
STRUCTURAL_OPS_SHEETS_LOG_EACH_MID_TOUCH=0
# Лист snapshot structural scan.
STRUCTURAL_LEVELS_REPORT_WORKSHEET=structural_levels_report
# Лист structural operational log.
STRUCTURAL_OPS_LOG_WORKSHEET=structural_ops_log

# ----------------------------- Stage telemetry -------------------------------
# Лог этапов в БД/логгер.
OPS_STAGE_LOG=1
# Telegram по этапам supervisor: 0 = минимум (только лог/БД/Sheets); 1 = пуши (см. ONLY_FINAL).
OPS_STAGE_TELEGRAM=1
# Если 1 — только финальные/ошибочные stage-сообщения (без start-спама).
OPS_STAGE_TELEGRAM_ONLY_FINAL=1
# Писать этапы в лист ops_stages.
OPS_STAGE_SHEETS=1
# Название листа stage-журнала.
OPS_STAGE_WORKSHEET=ops_stages

# ------------------------- Cycle-level sheets snapshots ----------------------
# Лист основного снимка cycle уровней.
CYCLE_LEVELS_WORKSHEET=cycle_levels_v1
# Лист диагностики причин выбора/невыбора.
CYCLE_LEVELS_DIAG_WORKSHEET=cycle_levels_diag_v1
# Лист детального списка кандидатов.
CYCLE_LEVELS_CANDIDATES_WORKSHEET=cycle_levels_candidates_v1

# ---------------------- Supervisor (единый авто-режим) ----------------------
# Включать supervisor loop автоматически (1) или запускать вручную с --loop.
SUPERVISOR_LOOP_ENABLED=0
# Базовый шаг цикла supervisor (сек) — как часто проверять таймеры этапов.
SUPERVISOR_POLL_SEC=2
# Период обновления данных (spot/macro/indices/oi/instruments), сек.
SUPERVISOR_DATA_REFRESH_SEC=900
# Пошаговый DATA_REFRESH (supervisor + load_all_data). Дефолты в коде: spot_main/instruments/atr=1; остальное=0.
# Раскомментируйте и поставьте 1, если нужен полный пайплайн аналитики.
#SUPERVISOR_DATA_REFRESH_SPOT_CRYPTO_CONTEXT=1
#SUPERVISOR_DATA_REFRESH_MACRO=1
#SUPERVISOR_DATA_REFRESH_INDICES_TV=1
#SUPERVISOR_DATA_REFRESH_OI_BYBIT=1
# Период пересчета локальных vp уровней и их выгрузки в Sheets, сек.
SUPERVISOR_LEVELS_REBUILD_SEC=1800
# Период запуска structural цикла (scan/realtime/freeze), сек.
SUPERVISOR_STRUCTURAL_SEC=1800
# 1 — не запускать плановый structural при levels_frozen и phase arming|in_position (не рвать V3 до закрытия цикла).
SUPERVISOR_STRUCTURAL_SKIP_WHEN_CYCLE_ACTIVE=1
# Если structural пропущен из‑за активного цикла — повторная проверка через N сек.
SUPERVISOR_STRUCTURAL_RETRY_WHEN_BLOCKED_SEC=120
# Перед structural: выгрузить vp_local из БД в лист (сверка). 0/false/off — отключить.
SUPERVISOR_EXPORT_VP_LOCAL_BEFORE_STRUCTURAL=1
# После пересчёта vp_local в supervisor: выгрузка листа vp_local_levels (источник кандидатов).
SUPERVISOR_EXPORT_VP_LOCAL_AFTER_LEVELS_REBUILD=1
# structural_levels_report_v2/v4 отключены и не используются supervisor'ом.
# Период entry тикa (monitor + gate + maintenance + reconcile), сек.
SUPERVISOR_ENTRY_TICK_SEC=10

# FAST one-pass supervisor (separate entrypoint: python -m trading_bot.scripts.run_supervisor_fast)
# Позволяет быстро прогнать structural/entry без ожидания полного loop.
# По умолчанию fast-скрипт берет весь TRADING_SYMBOLS (FAST_USE_ALL_TRADING_SYMBOLS=1).
FAST_RUN_DATA_REFRESH=0
FAST_RUN_LEVELS_REBUILD=0
FAST_RUN_STRUCTURAL=1
FAST_RUN_ENTRY_TICK=1
FAST_USE_ALL_TRADING_SYMBOLS=1
# Используется только когда FAST_USE_ALL_TRADING_SYMBOLS=0
# FAST_SYMBOLS=BTC/USDT,ETH/USDT,LINK/USDT,NEAR/USDT
# Лимит одновременно открытых позиций на одно направление.
MAX_POSITIONS_PER_SIDE=10

# ---------------------- Google Sheets: торговый контур (MARKET_AUDIT книга) ---
# После reconcile в entry-тике: лист открытых позиций по cycle_id + append закрытых в статистику.
SHEETS_TRADING_CYCLE_SYNC=1
CYCLE_OPEN_POSITIONS_WORKSHEET=cycle_open_positions
CYCLE_TRADING_STATS_WORKSHEET=cycle_trading_stats
# WebSocket цен (см. settings.py): при проблемах stream-demo — PRICE_FEED_WEBSOCKET_ENABLED=0

# ----------------------------------------------------------------------------
# Памятка:
# - Если STRUCTURAL_REF_PRICE_SOURCE=db_1m_close, поддерживайте свежий 1m в БД:
#   python -m trading_bot.scripts.sync_binance_1m_spot
#   python trading_bot/entrypoints/load_all_data.py
# ----------------------------------------------------------------------------
