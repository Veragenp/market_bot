# ============================================================================
# Volume Peaks (локальные уровни) – настройки для расчёта объёмных пиков (vp_local)
# ============================================================================

# Название листа в Google Sheets, куда выгружаются локальные уровни vp_local
VOLUME_PEAK_LEVELS_WORKSHEET=vp_local_levels

# Как часто (в часах) пересчитывать vp_local и обновлять таблицу price_levels.
# 0 = только ежедневный слот 02:45 UTC.
VP_LOCAL_REBUILD_INTERVAL_HOURS=4

# Если после пересчёта для символа не найдено ни одного уровня, удалять старые активные vp_local
# (1 – да, 0 – оставить старый снимок для отладки)
VP_LOCAL_CLEAR_ON_EMPTY_REBUILD=1


# ============================================================================
# Structural v4 – независимые наборы long/short, без эталона (W*)
# ============================================================================

# Источник референсной цены для structural:
#   price_feed  – текущая цена через WebSocket/REST (рекомендуется)
#   db_1m_close – последний close из SQLite (если цена недоступна)
STRUCTURAL_REF_PRICE_SOURCE=price_feed

# Типы уровней, которые разрешены для отбора в structural (через запятую).
# vp_local – локальные объёмные пики, manual_global_hvn – ручные глобальные уровни из Sheets.
STRUCTURAL_ALLOWED_LEVEL_TYPES=vp_local,manual_global_hvn

# Минимальное количество кандидатов на сторону (long или short) для одного символа.
STRUCTURAL_MIN_CANDIDATES_PER_SIDE=1

# Сколько сильнейших уровней (по volume_peak) брать в кандидаты для каждой стороны.
STRUCTURAL_TOP_K=4

# Минимальная ширина канала (U – L) в ATR для допустимой пары.
STRUCTURAL_W_MIN=0.7

# Максимальная ширина канала (U – L) в ATR для допустимой пары.
STRUCTURAL_W_MAX=2.5

# Минимальное количество символов в пуле (с хотя бы одной стороной), чтобы structural считался успешным.
STRUCTURAL_MIN_POOL_SYMBOLS=5

# Автоматически замораживать уровни в cycle_levels после успешного скана (1 – да, 0 – только скан).
STRUCTURAL_AUTO_FREEZE_ON_SCAN=1

# Нижняя граница ATR-полосы для поиска уровней (в ATR от референсной цены).
STRUCTURAL_V4_BAND_MIN_ATR=1.5

# Верхняя граница ATR-полосы для поиска уровней (в ATR от референсной цены).
STRUCTURAL_V4_BAND_MAX_ATR=4.5

# Разрешить перестроение противоположной стороны канала при флипе (1 – да, 0 – нет).
STRUCTURAL_OPPOSITE_REBUILD_ENABLED=1

# Множитель для расширения диапазона при rebuild opposite.
# Итоговый диапазон: [STRUCTURAL_W_MIN * MULT, STRUCTURAL_W_MAX * MULT].
STRUCTURAL_OPPOSITE_REBUILD_BAND_MULT=2


# ============================================================================
# Level Cross Monitor / Entry Gate (групповой сигнал с таймером)
# ============================================================================

# Частота опроса цен и проверки пересечений уровней (в секундах).
LEVEL_CROSS_POLL_SEC=10

# Таймаут (в минутах) после набора минимального количества алертов.
# Если за это время не произошло отмены, выдаётся групповой сигнал.
LEVEL_CROSS_ALERT_TIMEOUT_MINUTES=5

# Минимальное количество разных монет, пересекших свои уровни, для запуска окна ожидания.
LEVEL_CROSS_MIN_ALERTS_COUNT=2

# Допустимое количество «лишних» алертов после старта окна.
# При превышении сценарий отменяется (collective_breakout).
LEVEL_CROSS_MAX_ADDITIONAL_ALERTS=10

# Логировать в INFO каждый тик монитора (1 – да, 0 – нет).
LEVEL_CROSS_TICK_SUMMARY_LOG=1

# Включить Telegram-уведомления для level_cross/entry контура (1 – да, 0 – нет).
LEVEL_CROSS_TELEGRAM=1

# Уведомлять о каждом пересечении уровня (очень шумно) – 1 или 0.
LEVEL_CROSS_TELEGRAM_CROSSINGS=1

# Отправлять Telegram при старте каждого тика entry_detector (1 – да, 0 – нет).
ENTRY_DETECTOR_TELEGRAM_START=1

# Порог подтверждения входа LONG (% от ATR уровня). Цена должна быть не ниже уровня минус этот процент.
ENTRY_GATE_LONG_ATR_THRESHOLD_PCT=0

# Порог подтверждения входа SHORT (% от ATR уровня). Цена должна быть не выше уровня плюс этот процент.
ENTRY_GATE_SHORT_ATR_THRESHOLD_PCT=0

# Автоматически выставлять лимитные ордера после подтверждения гейта (1 – да, 0 – только логи).
ENTRY_AUTO_OPEN_AFTER_GATE=1

# При получении противоположного сигнала (флип) закрывать текущую позицию рынком (reduce-only).
ENTRY_CLOSE_OPPOSITE_ON_FLIP_SIGNAL=1

# Если после reconcile все позиции закрыты – автоматически закрыть freeze-эпоху (cycle_phase=closed).
ENTRY_PACKAGE_FLAT_TRANSITION=1

# Использовать Bybit для проверки flat (нужны ключи). 0 – только position_records.
ENTRY_PACKAGE_FLAT_USE_BYBIT_POSITIONS=1


# ============================================================================
# Supervisor (единый оркестратор всех этапов)
# ============================================================================

# Запускать supervisor в бесконечном цикле (1 – да, 0 – только один проход).
SUPERVISOR_LOOP_ENABLED=1

# Базовый шаг цикла supervisor (сек) – как часто проверять таймеры этапов.
SUPERVISOR_POLL_SEC=2

# Интервал обновления рыночных данных (spot, macro, indices, OI, instruments) – секунды.
SUPERVISOR_DATA_REFRESH_SEC=900

# Интервал пересчёта локальных уровней vp_local (сек).
SUPERVISOR_LEVELS_REBUILD_SEC=1800

# Интервал запуска structural цикла (скан + freeze) – секунды.
SUPERVISOR_STRUCTURAL_SEC=1800

# Не запускать плановый structural, если уровни заморожены (levels_frozen=1) и цикл активен.
SUPERVISOR_STRUCTURAL_SKIP_WHEN_CYCLE_ACTIVE=1

# Если structural пропущен из‑за активного цикла – через сколько секунд проверить снова.
SUPERVISOR_STRUCTURAL_RETRY_WHEN_BLOCKED_SEC=120

# Интервал тика entry detector (монитор пересечений + гейт + reconcile) – секунды.
SUPERVISOR_ENTRY_TICK_SEC=10

# Перед запуском structural выгрузить vp_local из БД в Google Sheets (для сверки).
SUPERVISOR_EXPORT_VP_LOCAL_BEFORE_STRUCTURAL=1

# После пересчёта vp_local выгрузить их в Sheets.
SUPERVISOR_EXPORT_VP_LOCAL_AFTER_LEVELS_REBUILD=1

# Включить/выключить отдельные шаги DATA_REFRESH (1 – вкл, 0 – выкл)
SUPERVISOR_DATA_REFRESH_SPOT_MAIN=1        # Основные spot-символы (TRADING_SYMBOLS)
SUPERVISOR_DATA_REFRESH_SPOT_CRYPTO_CONTEXT=0  # Дополнительные crypto‑context символы
SUPERVISOR_DATA_REFRESH_MACRO=0            # Макроэкономические данные (SP500, DXY...)
SUPERVISOR_DATA_REFRESH_INDICES_TV=0       # Индексы TradingView (TOTAL, BTCD...)
SUPERVISOR_DATA_REFRESH_OI_BYBIT=0         # Open Interest Bybit
SUPERVISOR_DATA_REFRESH_INSTRUMENTS=1      # Инструменты (tick_size, min_qty...)
SUPERVISOR_DATA_REFRESH_INSTRUMENTS_ATR=1  # ATR для инструментов


