STRUCTURAL_LEVELS_REPORT_WORKSHEET=structural_levels_report

# Экспортировать structural-снимки в Sheets (1 – да)
STRUCTURAL_OPS_SHEETS_LEVELS=1

# Экспортировать операционный лог structural (0 – нет, 1 – да)
